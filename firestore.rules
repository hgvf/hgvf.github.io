rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ───────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isWhitelisted() {
      return isSignedIn() &&
        request.auth.token.email in
          get(/databases/$(database)/documents/config/auth).data.allowed_emails;
    }

    // ─── Public read-only collections ──────────────────────────────────────
    match /sectors/{id} {
      allow read: if true;
      allow write: if isWhitelisted();
    }

    match /subsectors/{id} {
      allow read: if true;
      allow write: if isWhitelisted();
    }

    match /tickers/{id} {
      allow read: if true;
      allow write: if isWhitelisted();
    }

    match /analysis/{id} {
      allow read: if true;
      allow write: if isWhitelisted();
    }

    match /research_notes/{id} {
      allow read: if true;
      allow write: if isWhitelisted();
    }

    // ─── Prices — public read, no client write (Worker uses service account via REST) ──
    match /prices/{symbol} {
      allow read: if true;
      allow write: if false;
    }

    // ─── Config ─────────────────────────────────────────────────────────────
    // config/auth — read by any signed-in user (needed for whitelist check),
    //               write only by whitelisted users.
    match /config/auth {
      allow read: if isSignedIn();
      allow write: if isWhitelisted();
    }

    // config/worker — read by whitelisted users only (contains trigger_secret),
    //                 write via Firebase Console only (set write=false here).
    match /config/worker {
      allow read: if isWhitelisted();
      allow write: if false;
    }
  }
}
