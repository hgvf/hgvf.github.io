rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isWhitelisted() {
      return isSignedIn() &&
        request.auth.token.email in
          get(/databases/$(database)/documents/config/auth).data.allowed_emails;
    }

    match /sectors/{id} {
      allow read: if true;
      allow write: if isWhitelisted();
    }
    match /subsectors/{id} {
      allow read: if true;
      allow write: if isWhitelisted();
    }
    match /tickers/{id} {
      allow read: if true;
      allow write: if isWhitelisted();
    }
    match /analysis/{id} {
      allow read: if true;
      allow write: if isWhitelisted();
    }
    match /research_notes/{id} {
      allow read: if true;
      allow write: if isWhitelisted();
    }
    match /prices/{symbol} {
      allow read: if true;
      allow write: if false;
    }
    match /config/auth {
      allow read: if isSignedIn();
      allow write: if isWhitelisted();
    }
    match /config/worker {
      allow read: if isWhitelisted();
      allow write: if false;
    }
  }
}
